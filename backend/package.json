{
  "name": "stremio-letterboxd-backend",
  "version": "1.2.2",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const{cpSync,existsSync}=require('fs');if(existsSync('src/db/migrations'))cpSync('src/db/migrations','dist/db/migrations',{recursive:true});\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@esp4ce/letterboxd-client": "^1.5.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "jose": "^5.0.0",
    "lru-cache": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "posthog-node": "^5.30.6",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "msw": "^2.13.6",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
